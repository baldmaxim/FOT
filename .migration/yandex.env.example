# Template для .migration/yandex.env — НЕ коммитим (см. .gitignore).
# Скопировать: cp .migration/yandex.env.example .migration/yandex.env
# Загружать в shell:  set -a; source .migration/yandex.env; set +a

# ─── SOURCE (Supabase production) ────────────────────────────────────
# Получить из Supabase Dashboard → Settings → Database → Connection string.
#
# ВАЖНО: использовать SESSION pooler (port 5432) или Direct connection,
# НЕ transaction pooler (port 6543) — pg_dump требует session-уровень
# (long-running transactions, COPY, snapshots).
#
# 1. SOURCE_DATABASE_URL — для psql / pg_dump / pg_restore (libpq).
#    sslmode=require → шифрование без верификации CA (Supabase pooler
#    отдаёт self-signed AWS-issued chain, libpq спокойно без CA).
#    keepalives=1 + idle/interval — спасают от ранних разрывов NLB при
#    редких/паузных запросах; на длинных активных COPY всё равно ловим
#    timeout — для skud_events используем chunked-стратегию.
SOURCE_DATABASE_URL="postgresql://postgres.<projectref>:<password>@aws-1-<region>.pooler.supabase.com:5432/postgres?sslmode=require&keepalives=1&keepalives_idle=30&keepalives_interval=10&keepalives_count=10"

# 2. SOURCE_DATABASE_URL_NODE — для TS-скриптов (Node `pg`).
#    Тот же DSN, но с uselibpqcompat=true — иначе pg-connection-string
#    интерпретирует sslmode=require как verify-full и падает на
#    self-signed AWS chain.
#    libpq (psql/pg_dump) этот параметр НЕ понимает, поэтому держим две DSN.
SOURCE_DATABASE_URL_NODE="postgresql://postgres.<projectref>:<password>@aws-1-<region>.pooler.supabase.com:5432/postgres?uselibpqcompat=true&sslmode=require&keepalives=1&keepalives_idle=30&keepalives_interval=10&keepalives_count=10"

# Не использовать production DATABASE_URL текущего fot-server'а как target.
# Это разные базы. Source — Supabase. Target — Yandex.

# ─── TARGET (Yandex Managed PG) ──────────────────────────────────────
# Один primary-хост. Multi-host через запятую с target_session_attrs=read-write
# работает нестабильно у Node `pg`, поэтому НЕ используем.
# Replica-хост держим в отдельной переменной для документации.
YANDEX_PRIMARY_HOST=rc1d-<rest>.mdb.yandexcloud.net
YANDEX_REPLICA_HOST=rc1b-<rest>.mdb.yandexcloud.net
YANDEX_PORT=6432
YANDEX_DB_NAME=<db_name>
YANDEX_DB_USER=<user>
YANDEX_DB_PASSWORD=<password>

# Yandex root CA для sslmode=verify-full.
# Скачать: curl -fsSL https://storage.yandexcloud.net/cloud-certs/CA.pem \
#            -o .migration/yandex-ca.pem
TARGET_SSL=true
# Абсолютный путь — Node-скрипты cwd'ом часто оказываются в fot-server/,
# тогда относительный путь не резолвится.
TARGET_SSL_CA_PATH=C:/path/to/repo/.migration/yandex-ca.pem

# TARGET_DATABASE_URL для psql, Node pg, pg_dump. ОБЯЗАТЕЛЬНО в двойных
# кавычках — `&` иначе становится bash background-оператором.
TARGET_DATABASE_URL="postgres://<user>:<password>@rc1d-<rest>.mdb.yandexcloud.net:6432/<db_name>?sslmode=verify-full&sslrootcert=C:/path/to/repo/.migration/yandex-ca.pem"

# ─── Storage migration (skud-object-maps + другие S3) ────────────────
# Supabase Storage source (REST). Из Supabase Dashboard.
SOURCE_SUPABASE_URL=https://<projectref>.supabase.co
SOURCE_SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Target — любой S3-compatible storage.
# В rehearsal'е использован Cloud.ru S3 (s3.cloud.ru). Можно подменить на
# Yandex Object Storage (storage.yandexcloud.net) — параметры одни и те же.
TARGET_OBJECT_STORAGE_ENDPOINT=https://s3.cloud.ru
TARGET_OBJECT_STORAGE_REGION=ru-central-1
TARGET_OBJECT_STORAGE_ACCESS_KEY_ID=<access_key_id>
TARGET_OBJECT_STORAGE_SECRET_ACCESS_KEY=<secret_key>
# path-style: для bucket с точкой в имени (например, "fot.app") обязательно
# true — иначе virtual-hosted SSL cert mismatch.
TARGET_OBJECT_STORAGE_FORCE_PATH_STYLE=true
TARGET_BUCKET=<bucket_name>

# ─── skud_events migration mode ──────────────────────────────────────
# Семейство `public.skud_events` (parent + 19 партиций + quarantine) НЕ
# мигрируется через pg_dump/pg_restore из Supabase из-за NLB session timeout
# на больших COPY. Принят production-путь: **manual Sigur API backfill**
# через `presence-polling` runtime после cutover. Detail и verification —
# docs/yandex-postgres-migration/09_skud_events_migration.md.
#
# Эти флаги читает scripts/yandex-migration/verify-public-data.ts. По default
# (без флагов) skud_events* diff → exit 1 (production-readiness gate).
# Чтобы verify пропустил skud_events* как accepted, оба флага должны быть
# выставлены:
#
#   SKUD_EVENTS_MIGRATION_MODE=sigur_api_manual
#   CONFIRM_SKUD_EVENTS_MANUAL_BACKFILL=true
#
# CONFIRM ставить true **только если owner/operator явно подтвердил manual
# Sigur backfill как production-путь** (acceptance gate из 09-документа
# пройден: retention проверена, backfill-runbook готов, verification-запросы
# приложены к cutover-runbook). Иначе оставить false — это soft-gate против
# случайного пропуска.
SKUD_EVENTS_MIGRATION_MODE=sigur_api_manual
CONFIRM_SKUD_EVENTS_MANUAL_BACKFILL=false

# ─── PowerShell / Windows notes ──────────────────────────────────────
# Bash из Git for Windows читает .env через `source` корректно.
# Если используете PowerShell — load через:
#   Get-Content .migration/yandex.env | ForEach-Object { ... } (костыль).
# Проще запускать миграционные команды из Git Bash (`bash`/`sh`).
#
# psql/pg_dump/pg_restore нужны минимум v17 (matching source/target).
# Установить через scoop: `scoop install postgresql` (даст v18.x).
# Добавить в PATH: /c/Users/<you>/scoop/apps/postgresql/current/bin

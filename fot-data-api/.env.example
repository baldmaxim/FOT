# Те же значения, что и в fot-server/.env
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Локальный порт сервиса (на проде доступ через nginx /external/v1/*)
PORT=4001

# Лимит по умолчанию для ключей без явного значения (запасной вариант,
# обычно используется значение из data_api_keys.rate_limit_per_minute)
DEFAULT_RATE_LIMIT_PER_MINUTE=60

{
  "name": "fot-server",
  "version": "1.0.0",
  "description": "FOT Backend Server with encryption and 2FA",
  "packageManager": "npm@11.6.2",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "sentry:sourcemaps": "sentry-cli sourcemaps inject ./dist && sentry-cli sourcemaps upload --release=$SENTRY_RELEASE ./dist",
    "test": "vitest run",
    "audit:routes": "tsx scripts/audit-route-protection.ts",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1017.0",
    "@aws-sdk/s3-request-presigner": "^3.1017.0",
    "@sentry/node": "^10.50.0",
    "@sentry/profiling-node": "^10.50.0",
    "@types/archiver": "^7.0.0",
    "@types/web-push": "^3.6.4",
    "archiver": "^7.0.1",
    "axios": "^1.15.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "fast-xml-parser": "^5.9.3",
    "heic-convert": "^2.1.0",
    "helmet": "^8.0.0",
    "imapflow": "^1.4.3",
    "jsonwebtoken": "^9.0.2",
    "jszip": "^3.10.1",
    "lru-cache": "^11.3.0",
    "mailparser": "^3.9.12",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^9.0.3",
    "otpauth": "^9.3.1",
    "pg": "^8.20.0",
    "qrcode": "^1.5.4",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "web-push": "^3.6.7",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
    "zod": "^3.23.8"
  },
  "overrides": {
    "uuid": "^11.1.1"
  },
  "devDependencies": {
    "@sentry/cli": "^3.4.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/heic-convert": "^2.1.1",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/mailparser": "^3.4.6",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.5.5",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "@types/qrcode": "^1.5.5",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^4.1.1"
  }
}

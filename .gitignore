# OS files
.DS_Store
**/.DS_Store
Thumbs.db

# Archives
*.zip

# Binaries / installers
*.exe
# Установщик Sigur Reader EH отдаётся как статика фронта (см. DEPLOY.md)
!fot-app/public/downloads/*.exe

# Screenshots in repo root (Windows-style names)
/Снимок*.png
/Screenshot*.png
/screenshot*.png

# Agent scratch files
/memory.md
/Pre-prod

# Temporary exports
exports/

# Dependencies
node_modules/
/package-lock.json

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# Local SSH credentials (keys, passwords) — never commit
.ssh/

# Environment variables (IMPORTANT - contains secrets!)
.env
.env.local
.env.*.local
yandex.env
docs/yandex-postgres-migration/yandex.env
# .migration/ содержит миграционные артефакты (dumps, креды, CA, отчёты).
# Игнорируем всё кроме .example-шаблона и README — на любом уровне дерева
# (корень репо и fot-server/, скрипты пишут отчёты в свой ./. migration).
**/.migration/*
!**/.migration/yandex.env.example
!**/.migration/README.md

# Claude Code session artifacts (lock-файлы scheduled tasks и т.п.)
.claude/scheduled_tasks.lock

# Agent skills (transitions.dev и пр.) — локальные артефакты тулинга:
# реальные файлы скилла, симлинк в .claude/skills, лок-файл и MCP-конфиг.
# Не код приложения, на прод не нужны.
.agents/
.claude/skills/
skills-lock.json
.mcp.json

# Build output
dist/
build/
*.tsbuildinfo
.vite/
.eslintcache

# Logs
logs/
*.log
npm-debug.log*

# IDE
.idea/
.vscode/
*.swp
*.swo

# Testing
coverage/

# Temporary files
tmp/
temp/

# Data exports
*.xlsx
*.xls

# Бланки для скачивания — статика фронта, должны быть в репо
!fot-app/public/forms/*.xlsx

# Local agent scratch
.codex-skill-build/

# Unused Go modules (future migration)
fot-core/
fot-worker/
shared/

temp/
test/


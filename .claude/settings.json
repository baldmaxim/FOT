{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git *)",
            "shell": "bash",
            "command": "node \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/git-guard.cjs\"",
            "timeout": 10,
            "statusMessage": "git-guard"
          }
        ]
      }
    ]
  }
}

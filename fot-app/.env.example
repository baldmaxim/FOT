VITE_API_URL=http://localhost:3001/api

# Sentry (sentry.io). Оставь пустым в dev — Sentry не активируется.
VITE_SENTRY_DSN=

# Только для CI/build-машины: токен из sentry.io → Settings → Auth Tokens
# с правами project:read, project:releases, org:read.
# Используется @sentry/vite-plugin для загрузки sourcemaps.
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=fot-app
